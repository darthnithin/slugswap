# Required for most API routes that use Drizzle + Neon
DATABASE_URL=postgresql://

# Required for /api/users/profile
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Required for GET integration routes
GET_LOGIN_URL=https://get.cbord.com/ucsc/full/login.php?mobileapp=1
GET_API_BASE_URL=https://services.get.cbord.com/GETServices/services/json
GET_SYSTEM_USERNAME=get_mobile
GET_SYSTEM_PASSWORD=NOTUSED
GET_SYSTEM_DOMAIN=
GET_CREDENTIAL_SECRET=<strong-random-secret-for-pin-encryption>
