{
  "name": "slugswap-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:dashboard",
    "dev:dashboard": "dotenv -e .env -- npm run dev -w @slugswap/dashboard --",
    "dev:mobile": "npm run start:mobile",
    "build": "npm run build:dashboard",
    "build:dashboard": "npm run build -w @slugswap/dashboard",
    "start": "npm run start:mobile",
    "start:mobile": "npm run start -w @slugswap/mobile",
    "start:dashboard": "npm run start -w @slugswap/dashboard",
    "ios": "npm run ios -w @slugswap/mobile",
    "android": "npm run android -w @slugswap/mobile",
    "web": "npm run web -w @slugswap/mobile",
    "deploy:dashboard": "vercel --cwd apps/dashboard",
    "deploy:dashboard:prod": "vercel --cwd apps/dashboard --prod",
    "typecheck": "npm run typecheck:root && npm run typecheck:dashboard && npm run typecheck:mobile",
    "typecheck:root": "tsc --noEmit -p tsconfig.json",
    "typecheck:dashboard": "npm run typecheck -w @slugswap/dashboard",
    "typecheck:mobile": "npm run typecheck -w @slugswap/mobile",
    "mobile:start": "npm run start:mobile",
    "mobile:android": "npm run android",
    "mobile:ios": "npm run ios",
    "mobile:web": "npm run web",
    "dashboard:dev": "npm run dev:dashboard",
    "dashboard:build": "npm run build:dashboard",
    "dashboard:start": "npm run start:dashboard",
    "dashboard:deploy": "npm run deploy:dashboard",
    "dashboard:deploy:prod": "npm run deploy:dashboard:prod",
    "ci:check": "npm run typecheck",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@expo/cli": "^54.0.23",
    "@neondatabase/serverless": "^1.0.2",
    "@supabase/supabase-js": "^2.95.3",
    "better-auth": "^1.4.18",
    "drizzle-orm": "^0.45.1",
    "next": "^15.5.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "vercel": "^50.14.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.3.0",
    "@types/react": "~19.1.10",
    "@vercel/node": "^5.6.0",
    "cors": "^2.8.6",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "express": "^5.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
